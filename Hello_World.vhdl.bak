library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

entity DE0_CV_VGA_HELLO is
    port (
        CLOCK_50 : in  std_logic;

        VGA_HS   : out std_logic;
        VGA_VS   : out std_logic;
        VGA_R    : out std_logic_vector(3 downto 0);
        VGA_G    : out std_logic_vector(3 downto 0);
        VGA_B    : out std_logic_vector(3 downto 0)
    );
end entity DE0_CV_VGA_HELLO;

architecture rtl of DE0_CV_VGA_HELLO is

    -- 640 x 480 @ about 60 Hz VGA timing
    -- Horizontal: 640 visible, 16 front porch, 96 sync, 48 back porch
    -- Vertical:   480 visible, 10 front porch, 2 sync, 33 back porch
    constant H_VISIBLE : integer := 640;
    constant H_FRONT   : integer := 16;
    constant H_SYNC    : integer := 96;
    constant H_BACK    : integer := 48;
    constant H_TOTAL   : integer := H_VISIBLE + H_FRONT + H_SYNC + H_BACK;

    constant V_VISIBLE : integer := 480;
    constant V_FRONT   : integer := 10;
    constant V_SYNC    : integer := 2;
    constant V_BACK    : integer := 33;
    constant V_TOTAL   : integer := V_VISIBLE + V_FRONT + V_SYNC + V_BACK;

    constant CHAR_W   : integer := 8;
    constant CHAR_H   : integer := 8;
    constant SCALE    : integer := 4;
    constant TEXT_LEN : integer := 11; -- "hello world"

    constant TEXT_X : integer := (H_VISIBLE - (TEXT_LEN * CHAR_W * SCALE)) / 2;
    constant TEXT_Y : integer := (V_VISIBLE - (CHAR_H * SCALE)) / 2;

    signal pixel_tick : std_logic := '0';
    signal h_count    : integer range 0 to H_TOTAL - 1 := 0;
    signal v_count    : integer range 0 to V_TOTAL - 1 := 0;
    signal active     : std_logic;
    signal text_pixel : std_logic := '0';

    subtype font_row_t is std_logic_vector(7 downto 0);

    constant CH_SPACE : integer := 0;
    constant CH_h     : integer := 1;
    constant CH_e     : integer := 2;
    constant CH_l     : integer := 3;
    constant CH_o     : integer := 4;
    constant CH_w     : integer := 5;
    constant CH_r     : integer := 6;
    constant CH_d     : integer := 7;

    function message_char(index : integer) return integer is
    begin
        case index is
            when 0      => return CH_h;
            when 1      => return CH_e;
            when 2      => return CH_l;
            when 3      => return CH_l;
            when 4      => return CH_o;
            when 5      => return CH_SPACE;
            when 6      => return CH_w;
            when 7      => return CH_o;
            when 8      => return CH_r;
            when 9      => return CH_l;
            when 10     => return CH_d;
            when others => return CH_SPACE;
        end case;
    end function;

    function font_row(ch : integer; row : integer) return font_row_t is
    begin
        case ch is
            when CH_h =>
                case row is
                    when 0 => return "11000000";
                    when 1 => return "11000000";
                    when 2 => return "11011100";
                    when 3 => return "11100110";
                    when 4 => return "11000110";
                    when 5 => return "11000110";
                    when 6 => return "11000110";
                    when others => return "00000000";
                end case;

            when CH_e =>
                case row is
                    when 0 => return "00000000";
                    when 1 => return "00000000";
                    when 2 => return "00111100";
                    when 3 => return "01100110";
                    when 4 => return "01111110";
                    when 5 => return "01100000";
                    when 6 => return "00111110";
                    when others => return "00000000";
                end case;

            when CH_l =>
                case row is
                    when 0 => return "01100000";
                    when 1 => return "01100000";
                    when 2 => return "01100000";
                    when 3 => return "01100000";
                    when 4 => return "01100000";
                    when 5 => return "01100000";
                    when 6 => return "00111100";
                    when others => return "00000000";
                end case;

            when CH_o =>
                case row is
                    when 0 => return "00000000";
                    when 1 => return "00000000";
                    when 2 => return "00111100";
                    when 3 => return "01100110";
                    when 4 => return "01100110";
                    when 5 => return "01100110";
                    when 6 => return "00111100";
                    when others => return "00000000";
                end case;

            when CH_w =>
                case row is
                    when 0 => return "00000000";
                    when 1 => return "00000000";
                    when 2 => return "11000011";
                    when 3 => return "11000011";
                    when 4 => return "11011011";
                    when 5 => return "11011011";
                    when 6 => return "01100110";
                    when others => return "00000000";
                end case;

            when CH_r =>
                case row is
                    when 0 => return "00000000";
                    when 1 => return "00000000";
                    when 2 => return "11011100";
                    when 3 => return "11100110";
                    when 4 => return "11000000";
                    when 5 => return "11000000";
                    when 6 => return "11000000";
                    when others => return "00000000";
                end case;

            when CH_d =>
                case row is
                    when 0 => return "00000110";
                    when 1 => return "00000110";
                    when 2 => return "00111110";
                    when 3 => return "01100110";
                    when 4 => return "01100110";
                    when 5 => return "01100110";
                    when 6 => return "00111110";
                    when others => return "00000000";
                end case;

            when others =>
                return "00000000";
        end case;
    end function;

begin

    -- Divide 50 MHz board clock by 2 to get 25 MHz pixel updates.
    process (CLOCK_50)
    begin
        if rising_edge(CLOCK_50) then
            pixel_tick <= not pixel_tick;

            if pixel_tick = '1' then
                if h_count = H_TOTAL - 1 then
                    h_count <= 0;

                    if v_count = V_TOTAL - 1 then
                        v_count <= 0;
                    else
                        v_count <= v_count + 1;
                    end if;
                else
                    h_count <= h_count + 1;
                end if;
            end if;
        end if;
    end process;

    -- Active-low VGA sync pulses.
    VGA_HS <= '0' when h_count >= H_VISIBLE + H_FRONT and
                       h_count <  H_VISIBLE + H_FRONT + H_SYNC
              else '1';

    VGA_VS <= '0' when v_count >= V_VISIBLE + V_FRONT and
                       v_count <  V_VISIBLE + V_FRONT + V_SYNC
              else '1';

    active <= '1' when h_count < H_VISIBLE and v_count < V_VISIBLE else '0';

    -- Determine whether the current pixel is part of the text.
    process (h_count, v_count)
        variable local_x    : integer;
        variable local_y    : integer;
        variable char_index : integer;
        variable char_col   : integer;
        variable char_row   : integer;
        variable glyph      : font_row_t;
    begin
        text_pixel <= '0';

        if h_count >= TEXT_X and
           h_count < TEXT_X + TEXT_LEN * CHAR_W * SCALE and
           v_count >= TEXT_Y and
           v_count < TEXT_Y + CHAR_H * SCALE then

            local_x    := h_count - TEXT_X;
            local_y    := v_count - TEXT_Y;

            char_index := local_x / (CHAR_W * SCALE);
            char_col   := (local_x / SCALE) mod CHAR_W;
            char_row   := (local_y / SCALE) mod CHAR_H;

            glyph := font_row(message_char(char_index), char_row);

            if glyph(7 - char_col) = '1' then
                text_pixel <= '1';
            end if;
        end if;
    end process;

    -- White text on black background.
    process (active, text_pixel)
    begin
        if active = '1' and text_pixel = '1' then
            VGA_R <= "1111";
            VGA_G <= "1111";
            VGA_B <= "1111";
        else
            VGA_R <= "0000";
            VGA_G <= "0000";
            VGA_B <= "0000";
        end if;
    end process;

end architecture rtl;       